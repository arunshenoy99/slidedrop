{
  "name": "slidedrop",
  "version": "1.0.0",
  "description": "Slidedrop — a self-updating PDF presentation viewer on Cloudflare Pages + R2",
  "private": true,
  "type": "module",
  "scripts": {
    "vendor": "cp node_modules/@hyzyla/pdfium/dist/index.esm.browser.js public/vendor/pdfium.mjs && cp node_modules/@hyzyla/pdfium/dist/pdfium.wasm public/vendor/pdfium.wasm",
    "dev": "wrangler pages dev public",
    "deploy": "wrangler pages deploy public",
    "deck:local": "wrangler r2 object put slidedrop-deck/deck.pdf --local --file",
    "deck:publish": "wrangler r2 object put slidedrop-deck/deck.pdf --remote --file",
    "deck:flatten": "node scripts/flatten.mjs"
  },
  "devDependencies": {
    "@hyzyla/pdfium": "^2.1.13",
    "wrangler": "^4.101.0"
  }
}
